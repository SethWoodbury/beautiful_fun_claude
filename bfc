#!/usr/bin/env bash
# bfc — configure beautiful_fun_claude animations without editing files by hand.
# Edits the CONFIG block of your installed statusline.sh (follows the symlink if any).
#
#   bfc                       show current settings
#   bfc on | off              enable / disable in-bar animation cameos
#   bfc every <seconds>       seconds between cameos        (e.g. bfc every 60)
#   bfc frames <n>            cameo length in ~1s frames    (e.g. bfc frames 6)
#   bfc only  <s> [s …]       play ONLY these animations    (e.g. bfc only seth race fish)
#   bfc add   <s> [s …]       add animations to the rotation
#   bfc exclude <s> [s …]     remove animations from the rotation
#   bfc all                   rotate through every animation
#   bfc list                  list every available animation
#   bfc status                same as `bfc` (show settings)
#
# Changes appear on your next interaction with Claude Code.
set -u
SL=$(readlink -f "$HOME/.claude/statusline.sh" 2>/dev/null || echo "$HOME/.claude/statusline.sh")
LIB="$HOME/.claude/statusline-animations.sh"
[ -f "$SL" ]  || { echo "bfc: not installed ($SL missing)" >&2; exit 1; }

cur() { grep -m1 "^$1=" "$SL" | sed "s/^$1=//; s/[[:space:]]*#.*//"; }
all_styles() { eval "$(sed -n '/^ALL_STYLES=/,/)/p' "$LIB" 2>/dev/null)"; printf '%s ' "${ALL_STYLES[@]}"; }
cur_styles() { eval "$(sed -n '/^ANIM_STYLES=(/,/)/p' "$SL" 2>/dev/null)"; printf '%s ' "${ANIM_STYLES[@]}"; }
set_scalar() { sed --follow-symlinks -i "s|^$1=[0-9][0-9]*|$1=$2|" "$SL" 2>/dev/null || sed -i "s|^$1=[0-9][0-9]*|$1=$2|" "$SL"; }
set_styles() { local -a a; read -r -a a <<<"$*"; local list="${a[*]}"; sed --follow-symlinks -i "s|^ANIM_STYLES=(.*)|ANIM_STYLES=($list)|" "$SL" 2>/dev/null || sed -i "s|^ANIM_STYLES=(.*)|ANIM_STYLES=($list)|" "$SL"; }
valid() { case " $(all_styles) " in *" $1 "*) return 0;; *) return 1;; esac; }

cmd="${1:-status}"; shift 2>/dev/null || true
case "$cmd" in
    on)      set_scalar ANIM_ENABLED 1; echo "✓ animations ON" ;;
    off)     set_scalar ANIM_ENABLED 0; echo "✓ animations OFF" ;;
    every)   [[ "${1:-}" =~ ^[0-9]+$ ]] || { echo "usage: bfc every <seconds>" >&2; exit 1; }; set_scalar ANIM_EVERY "$1"; echo "✓ a cameo every ${1}s" ;;
    frames)  [[ "${1:-}" =~ ^[0-9]+$ ]] || { echo "usage: bfc frames <n>" >&2; exit 1; }; set_scalar ANIM_FRAMES "$1"; echo "✓ cameo length ${1} frames" ;;
    only)    [ $# -ge 1 ] || { echo "usage: bfc only <style> [style …]" >&2; exit 1; }
             for s in "$@"; do valid "$s" || { echo "bfc: unknown animation '$s' (try: bfc list)" >&2; exit 1; }; done
             set_styles "$*"; echo "✓ rotation: $*" ;;
    add)     [ $# -ge 1 ] || { echo "usage: bfc add <style> …" >&2; exit 1; }
             new=$(cur_styles)
             for s in "$@"; do valid "$s" || { echo "bfc: unknown '$s'" >&2; exit 1; }; case " $new " in *" $s "*) ;; *) new="$new$s ";; esac; done
             set_styles "$new"; echo "✓ rotation: $new" ;;
    exclude) [ $# -ge 1 ] || { echo "usage: bfc exclude <style> …" >&2; exit 1; }
             keep=""; for s in $(cur_styles); do drop=0; for x in "$@"; do [ "$s" = "$x" ] && drop=1; done; [ "$drop" -eq 0 ] && keep="$keep$s "; done
             set_styles "$keep"; echo "✓ rotation: $keep" ;;
    all)     set_styles "$(all_styles)"; echo "✓ rotation: all" ;;
    list)    echo "available animations:"; printf '  %s\n' $(all_styles) ;;
    status|"") printf 'beautiful_fun_claude — current settings (%s):\n' "$SL"
             printf '  enabled:   %s\n' "$(cur ANIM_ENABLED)"
             printf '  every:     %ss\n' "$(cur ANIM_EVERY)"
             printf '  frames:    %s\n' "$(cur ANIM_FRAMES)"
             printf '  rotation:  %s\n' "$(cur_styles)" ;;
    -h|--help|help) sed -n '2,21p' "$0" | sed 's/^# \{0,1\}//' ;;
    *)       echo "bfc: unknown command '$cmd' (try: bfc --help)" >&2; exit 1 ;;
esac
